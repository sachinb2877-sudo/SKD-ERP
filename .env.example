# ═══════════════════════════════════════════════════════════
# SKD ERP — Environment Variables
# ═══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# Variables prefixed with VITE_ are exposed to the frontend.
# NEVER commit the .env file — it may contain secrets.
# ═══════════════════════════════════════════════════════════

# ── App Settings ──────────────────────────────────────────
VITE_APP_NAME=SKD ERP
VITE_APP_VERSION=1.0.0

# ── Currency ──────────────────────────────────────────────
VITE_CURRENCY_SYMBOL=₹
VITE_CURRENCY_CODE=INR

# ── API (future backend) ─────────────────────────────────
# VITE_API_BASE_URL=http://localhost:5000/api

# ── Server (backend — when ready) ────────────────────────
# PORT=5000
# DATABASE_URL=mongodb://localhost:27017/skd-erp
# JWT_SECRET=your-secret-key-here
